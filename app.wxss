/* app.wxss */
page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
  font-size: 36rpx;          /* 适老化：基础字体偏大 */
  color: #333;
  background-color: #f5f5f5;
}

/* 通用按钮样式 - 大按钮 */
.btn-primary {
  width: 90%;
  margin: 20rpx auto;
  padding: 30rpx 0;
  background-color: #1296db;
  color: white;
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  border-radius: 20rpx;
  border: none;
}

.btn-primary:active {
  background-color: #0d7ab5;
}

.btn-danger {
  width: 90%;
  margin: 20rpx auto;
  padding: 30rpx 0;
  background-color: #e74c3c;
  color: white;
  font-size: 40rpx;
  font-weight: bold;
  text-align: center;
  border-radius: 20rpx;
}