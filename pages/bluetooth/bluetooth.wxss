/* pages/bluetooth/bluetooth.wxss */
.bt-container {
    padding: 30rpx;
    min-height: 100vh;
    background: #f5f5f5;
  }
  
  .bt-header {
    text-align: center;
    margin-bottom: 40rpx;
  }
  
  .bt-title {
    display: block;
    font-size: 44rpx;
    font-weight: bold;
    color: #333;
  }
  
  .bt-subtitle {
    display: block;
    font-size: 28rpx;
    color: #999;
    margin-top: 10rpx;
  }
  
  .connection-status {
    margin-bottom: 30rpx;
  }
  
  .status-card {
    padding: 40rpx;
    border-radius: 20rpx;
    text-align: center;
  }
  
  .status-connected {
    background: linear-gradient(135deg, #d4edda, #c3e6cb);
    border: 2rpx solid #27ae60;
  }
  
  .status-disconnected {
    background: linear-gradient(135deg, #f8d7da, #f5c6cb);
    border: 2rpx solid #e74c3c;
  }
  
  .status-icon {
    font-size: 60rpx;
    display: block;
  }
  
  .status-text {
    font-size: 40rpx;
    font-weight: bold;
    display: block;
    margin-top: 10rpx;
  }
  
  .device-name {
    font-size: 28rpx;
    color: #666;
    display: block;
    margin-top: 10rpx;
  }
  
  .bt-actions {
    margin-bottom: 30rpx;
  }
  
  .device-list {
    background: white;
    border-radius: 20rpx;
    padding: 20rpx;
    margin-bottom: 30rpx;
  }
  
  .list-title {
    display: block;
    font-size: 30rpx;
    color: #666;
    padding: 10rpx 0 20rpx;
  }
  
  .device-item {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 30rpx 20rpx;
    border-bottom: 1rpx solid #eee;
    border-radius: 10rpx;
    margin-bottom: 10rpx;
  }
  
  .device-item:active {
    background: #f0f0f0;
  }
  
  .hud-device {
    background: #e8f4fd;
    border: 2rpx solid #1296db;
  }
  
  .device-name-text {
    font-size: 34rpx;
    font-weight: bold;
    display: block;
  }
  
  .device-id {
    font-size: 22rpx;
    color: #999;
    display: block;
    margin-top: 6rpx;
  }
  
  .rssi-text {
    font-size: 26rpx;
    color: #666;
  }
  
  .test-section {
    background: white;
    border-radius: 20rpx;
    padding: 30rpx;
    margin-bottom: 30rpx;
  }
  
  .test-title {
    display: block;
    font-size: 34rpx;
    font-weight: bold;
    margin-bottom: 20rpx;
  }
  
  .test-result {
    display: block;
    font-size: 28rpx;
    color: #27ae60;
    margin-top: 20rpx;
    text-align: center;
  }
  
  .help-section {
    background: white;
    border-radius: 20rpx;
    padding: 30rpx;
  }
  
  .help-title {
    display: block;
    font-size: 34rpx;
    font-weight: bold;
    margin-bottom: 20rpx;
  }
  
  .help-text {
    display: block;
    font-size: 30rpx;
    color: #666;
    padding: 8rpx 0;
    line-height: 1.6;
  }