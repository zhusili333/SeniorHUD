<!-- pages/index/index.wxml -->
<view class="container">
  
  <!-- 地图区域 -->
  <map 
    id="mainMap"
    latitude="{{latitude}}"
    longitude="{{longitude}}"
    scale="15"
    show-location="true"
    style="width: 100%; height: 500rpx;"
    markers="{{markers}}"
    polyline="{{polyline}}"
  />

  <!-- 当前位置信息 -->
  <view class="location-info">
    <text class="location-label">📍 当前位置：</text>
    <text class="location-text">{{address || '定位中...'}}</text>
  </view>

  <!-- 目的地输入 -->
  <view class="search-box">
    <input 
      class="search-input"
      placeholder="请输入目的地"
      value="{{destination}}"
      bindinput="onDestInput"
      bindconfirm="onSearch"
    />
    <button class="search-btn" bindtap="onSearch">搜索</button>
  </view>

  <!-- 搜索结果列表 -->
  <view class="search-results" wx:if="{{searchResults.length > 0}}">
    <view 
      class="result-item" 
      wx:for="{{searchResults}}" 
      wx:key="id"
      bindtap="onSelectDest"
      data-index="{{index}}"
    >
      <text class="result-name">{{item.name}}</text>
      <text class="result-address">{{item.address}}</text>
    </view>
  </view>

  <!-- 功能按钮 -->
  <view class="btn-group">
    <button class="btn-primary" bindtap="onStartNav">
      🚗 开始导航
    </button>
    <button class="btn-primary" style="background-color: #27ae60;" bindtap="goToBluetooth">
      📡 连接HUD设备
    </button>
  </view>

  <!-- 连接状态 -->
  <view class="status-bar">
    <text class="status-dot {{isConnected ? 'connected' : 'disconnected'}}">●</text>
    <text class="status-text">HUD设备: {{isConnected ? '已连接' : '未连接'}}</text>
  </view>

</view>